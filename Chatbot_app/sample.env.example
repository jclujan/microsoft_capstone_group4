# Local development only. In Databricks Apps these are provided automatically
# via the bound 'sql_warehouse' resource and the app service principal.

# Required for SQL Warehouse access
DATABRICKS_SERVER_HOSTNAME=dbc-xxxxxxxx-xxxx.cloud.databricks.com
DATABRICKS_WAREHOUSE_ID=0123456789abcdef

# Local-only personal access token (NEVER commit, NEVER paste into the UI).
# In Databricks Apps, omit this — auth is automatic via the service principal.
DATABRICKS_TOKEN=

# LLM explanation layer: none | databricks | ollama  (default: none)
LLM_PROVIDER=none

# Optional Databricks serving endpoint for explanations
DATABRICKS_LLM_ENDPOINT=databricks-meta-llama-3-1-70b-instruct

# Optional Ollama config
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Performance tuning
CANDIDATE_LIMIT=800
DEFAULT_TOP_N=10

STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
